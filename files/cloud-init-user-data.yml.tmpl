#cloud-config
hostname: __VM_NAME__
manage_etc_hosts: true
package_update: true
package_upgrade: true

packages:
  - ca-certificates
  - curl
  - gnupg
  - jq
  - lsb-release
  - openssl
  - qemu-guest-agent
  - rsync
  - tar

write_files:
  - path: /root/bootstrap-psono.b64
    owner: root:root
    permissions: "0600"
    content: |
__BOOTSTRAP_B64__
  - path: /usr/local/sbin/psonoctl
    owner: root:root
    permissions: "0755"
    encoding: b64
    content: |
__PSONOCTL_B64__

runcmd:
  - [systemctl, enable, --now, qemu-guest-agent]
  - [bash, -lc, "base64 -d /root/bootstrap-psono.b64 > /root/bootstrap-psono.sh"]
  - [chmod, "0700", /root/bootstrap-psono.sh]
  - [bash, /root/bootstrap-psono.sh]

final_message: "Psono bootstrap finished. Check /var/log/psono-bootstrap.log and run: sudo psonoctl status"
