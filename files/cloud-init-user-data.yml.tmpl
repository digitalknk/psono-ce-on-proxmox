#cloud-config
hostname: __VM_NAME__
manage_etc_hosts: true
ssh_pwauth: __SSH_PWAUTH__

users:
  - default
__PSONO_USER_BLOCK__

__CHPASSWD_BLOCK__

write_files:
  - path: /root/bootstrap-psono.sh
    owner: root:root
    permissions: "0700"
    encoding: b64
    content: |
__BOOTSTRAP_B64__
  - path: /usr/local/sbin/psonoctl
    owner: root:root
    permissions: "0755"
    encoding: b64
    content: |
__PSONOCTL_B64__

runcmd:
  - [systemctl, enable, --now, qemu-guest-agent]
  - [bash, /root/bootstrap-psono.sh]

final_message: "Psono bootstrap finished. Check /var/log/psono-bootstrap.log and run: sudo psonoctl status"
